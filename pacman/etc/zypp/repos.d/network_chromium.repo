[network_chromium]
name=Chromium (openSUSE_Tumbleweed)
enabled=1
autorefresh=0
type=rpm-md
gpgcheck=1
gpgkey=https://download.opensuse.org/repositories/network:/chromium/openSUSE_Tumbleweed/repodata/repomd.xml.key
keeppackages=1
baseurl=https://cdn.opensuse.org/repositories/network:/chromium/openSUSE_Tumbleweed/
